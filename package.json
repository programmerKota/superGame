{
  "name": "supergame",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0 <25"
  },
  "scripts": {
    "dev": "vite",
    "check": "npm run check:source && npm run check:dependencies",
    "check:source": "node scripts/check-source.mjs",
    "check:dependencies": "node scripts/verify-dependencies.mjs",
    "test": "npm run test:unit",
    "test:unit": "node --test test/*.test.js",
    "test:e2e": "npm run build && playwright test",
    "validate": "npm run check && npm run test:unit && npm run build",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@cesium/engine": "19.0.0",
    "@cesium/widgets": "13.0.0",
    "@zip.js/zip.js": "2.7.70",
    "cesium": "1.132.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "vite": "6.0.0",
    "vite-plugin-static-copy": "2.3.2"
  },
  "overrides": {
    "@cesium/engine": "19.0.0",
    "@cesium/widgets": "13.0.0",
    "@zip.js/zip.js": "2.7.70"
  }
}
